<!-- BEGIN PAGE HEADER-->
<div class="row-fluid">
    <div class="span12">
        <!-- BEGIN THEME CUSTOMIZER-->
        <!-- END THEME CUSTOMIZER-->
        <!-- BEGIN PAGE TITLE & BREADCRUMB-->
        <h3 class="page-title"></h3>
        <ul class="breadcrumb">
            <li>
                <a href="#">Claims</a>
                <span class="divider">/</span>
            </li>
            <li>
                <a href="#">Claims Detail</a>
            </li>
        </ul>
        <!-- END PAGE TITLE & BREADCRUMB-->
    </div>
</div>



<!-- BEGIN EDITABLE TABLE widget-->
<div class="row-fluid">
    <div class="span12">
        <!-- BEGIN EXAMPLE TABLE widget-->
        <div class="widget green">
            <div class="widget-title">
                <h4>Claims Detail</h4>

            </div>

            <div class="container" style="margin-top:2px;">
                <div class="row">
                    <form class="form-inline">
                        <label class="control-label" style="display:inline">Starting*</label>
                        <input class="text-box single-line" id="StartingDate1" name="StartingDate1" style="height: 22px; width: 180px; margin-bottom: 0px;">
                        <label class="control-label" style="display:inline">Ending*</label>
                        <input class="text-box single-line" id="StartingDate2" name="StartingDate2" style="height: 22px; width: 180px; margin-bottom: 0px;">




                        <label class="control-label">Head *</label>

                        @Html.DropDownListFor(model => model.RegionalHeadID, new SelectList(Model.RegionalHead, "ID", "Name"), new { @class = "" })
                        @Html.ValidationMessageFor(model => model.RegionalHeadID)



                        <label class="control-label">Sales Officer *</label>

                        @Html.DropDownListFor(model => model.SaleOfficerID, new SelectList(Model.SaleOfficer, "ID", "Name"), new { @class = "" })
                        @Html.ValidationMessageFor(model => model.SaleOfficerID)
                        @Html.HiddenFor(model => model.ID)
                        @Html.HiddenFor(model => model.SelectedRetailers)

                        <button type="button" id="ApplyFilter" class="btn btn-primary">
                            <i class="icon-ok icon-white" style="padding-right: 2px"></i><span style="width:50px">Apply Filter</span>
                        </button>

                    </form>
                </div>
            </div>


            <div class="widget-body">
                <div>
                    <div class="clearfix">
                        @*<div class="control-group" style="margin-bottom: 14px; display:inline">
                                <label class="control-label" style="display:inline">Starting Date *</label>
                                <div class="controls" style="display:inline">
                                    <input class="text-box single-line" id="StartingDate1" name="StartingDate1" style="height: 22px; width: 202px; margin-bottom: 0px;">
                                </div>
                            </div>*@

                        @*<div class="control-group" style="margin-bottom: 14px; display:inline">
                                <label class="control-label" style="display:inline">Ending Date *</label>
                                <div class="controls" style="display:inline">
                                    <input class="text-box single-line" id="StartingDate2" name="StartingDate2" style="height: 22px; width: 202px; margin-bottom: 0px;">
                                </div>
                            </div>*@



                        @*<div class="control-group" style="margin-bottom: 14px; display:inline">
                                <label class="control-label" style="display:inline">Sales Officer *</label>
                                <div class="controls" style="display:inline">
                                    @Html.DropDownListFor(model => model.SaleOfficerID, new SelectList(Model.SaleOfficer, "ID", "Name"), new { @class = "" })

                                </div>
                            </div>*@
                        @*<div class="control-group" style="margin-bottom: 14px; display:inline">
                                <button type="button" class="btn btn-success" id="btn_search">Search</button>

                            </div>*@


                        <div class="btn-group pull-right"></div>
                    </div>
                    <div class="space15"></div>
                    <table class="table table-striped table-hover table-bordered" style="width: 100%;" id="datatab">
                        <thead>
                            <tr>
                                <th></th>
                                <th></th>
                                <th></th>
                                <th style="width: 10% !important">Sr #</th>

                                <th style="width:16% !important">
                                    Sales Officer
                                </th>


                                <th style="width:16% !important">
                                    Customer Name
                                </th>
                                <th style="width:16% !important">
                                    Trade Party Name
                                </th>
                                <th style="width:16% !important">
                                    Customer Address
                                </th>
                                <th style="width:16% !important">
                                    Region Name
                                </th>

                                <th style="width:16% !important">
                                    Visit Date
                                </th>
                                <th style="width:16% !important">
                                    Claim Date
                                </th>

                                <th style="width:16% !important">
                                    Total Sale
                                </th>

                                <th style="width:16% !important">
                                    Total Liters
                                </th>



                                <th style="width:10% !important">Action</th>

                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
        <!-- END EXAMPLE TABLE widget-->
    </div>
</div>
<!-- END EDITABLE TABLE widget-->
<!-- Shop Modal -->
<div id="ShopModal" class="modal hide fade in" role="dialog" style="width: 71%;height: 100%;top: 4%;left: 15%;overflow-y:scroll;">

    <div class="modal-dialog">

        <!-- Modal content-->
        <div class="modal-content">
            <div class="modal-header" style="border-bottom: 1px solid #e5e5e5;">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"
                        style="font-size: 30px; font-weight: bold; color: #000; opacity: 0.8;">
                    &times;
                </button>
            </div>

            <div class="modal-body" style="max-height: 80vh; overflow-y: auto;">

                <div class="span12">

                    <h2 style="margin-top: -10px;text-align:center;color: #62c462;font-weight: bolder;border-bottom: 1px solid #62c462;border-top: 1px solid #62c462;padding-bottom: 10px;padding-top: 10px;" id="jobstatus">Claim Details</h2>

                    <div class="span12" style="padding:5px">

                        <table class="table table-striped table-hover table-bordered">
                            <thead>
                                <tr>
                                    <th style="text-align:center;background: #545454;color: white;" colspan="2">Detail</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td style="padding: 19px  0px 19px  5px;"><span style="margin: 0px 0px 0px 0px;font-weight: 600;color: #376892;">Sales Officer</span></td>
                                    <td style="padding: 19px  0px 19px  5px;"><span id="saleOfficer" style=""></span></td>
                                </tr>

                                <tr>
                                    <td style="padding: 19px  0px 19px  5px;"><span style="margin: 0px 0px 0px 0px;font-weight: 600;color: #376892;">Customer Name/Trade Party Name</span></td>
                                    <td style="padding: 19px  0px 19px  5px;"><span id="SchoolShopName" style=""></span></td>
                                </tr>

                                <tr>
                                    <td style="padding: 19px  0px 19px  5px;"><span style="margin: 0px 0px 0px 0px;font-weight: 600;color: #376892;">Claim Picture</span></td>
                                    <td style="padding: 19px  0px 19px  5px;"><span id="ClaimPicture" style=""></span></td>
                                </tr>



                                <tr>
                                    <td style="padding: 18px  0px 18px  5px;"><span style="margin: 0px 0px 0px 0px;font-weight: 600;color: #376892;">Visted Date</span></td>
                                    <td style="padding: 18px  0px 18px  5px;"><span id="visitedDate" style=""></span></td>
                                </tr>

                            </tbody>
                        </table>

                    </div>



                    <div class="span12" style="padding-top: 10px;">

                        <table class="table table-bordered table-hover" id="tblVolumeItems" style="border: 2px solid #007bff;">
                            <thead style="background: linear-gradient(to right, #007bff, #0056b3); color: white;">
                                <tr>
                                    <th colspan="7" style="text-align:center; font-size: 18px; font-weight: bold;">
                                        Items in This Claim
                                    </th>
                                </tr>
                                <tr style="text-align: center;">
                                    <th style="width: 14.28%;">Brand Name</th>
                                    <th style="width: 14.28%;">Product Code</th>
                                    <th style="width: 14.28%;">Product Name</th>
                                    <th style="width: 14.28%;">Drum Value</th>
                                    <th style="width: 14.28%;">Gallon Value</th>
                                    <th style="width: 14.28%;">Qtr Value</th>
                                    <th style="width: 14.28%;">Sale Value</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>

                    </div>



                    <div class="span12" style="padding-top: 10px;">
                        <table class="table table-bordered table-hover" id="tblApprovals" style="border: 2px solid #20c997;">
                            <!-- Teal border -->
                            <thead style="background: linear-gradient(to right, #17a2b8, #20c997); color: white;">
                                <!-- Aquatic gradient -->
                                <tr>
                                    <th colspan="4" style="text-align: center; font-size: 18px; font-weight: bold;">
                                        Claim Approvals History
                                    </th>
                                </tr>
                                <tr style="text-align: center;">
                                    <th style="width: 14.28%;">Approved By</th>
                                    <th style="width: 14.28%;">Approved Status</th>
                                    <th style="width: 14.28%;">Approved At</th>
                                    <th style="width: 14.28%;">Remarks</th>

                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>







                </div>

            </div>

        </div>

    </div>

</div>
<!-- END Shop Modal -->
<!-- Modal to show full image -->
<!-- Full Image Modal -->
<style>
    /* Soft backdrop */
    .modal-backdrop {
        background-color: rgba(0, 0, 0, 0.75);
    }

    /* Modal styling */
    #imageModal .modal-content {
        border-radius: 10px;
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.4);
        background-color: #ffffff;
    }

    #imageModal .modal-header {
        background-color: #376892;
        color: white;
        border-top-left-radius: 10px;
        border-top-right-radius: 10px;
        padding: 1rem 1.25rem;
    }

        #imageModal .modal-header .close {
            color: white;
            opacity: 1;
            font-size: 1.5rem;
        }

    #imageModal .modal-body img {
        max-width: 100%;
        max-height: 80vh;
        border-radius: 8px;
        border: 4px solid #f1f1f1;
        transition: transform 0.3s ease, border-color 0.3s ease;
    }

        #imageModal .modal-body img:hover {
            transform: scale(1.02);
            border-color: #376892;
        }
</style>

<!-- Modal -->
<div id="imageModal" class="modal fade" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-image" style="margin-right: 8px;"></i> Claim Full Image
                </h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body text-center">
                <img id="fullImage" src="" alt="Claim Image" />
            </div>
        </div>
    </div>
</div>



