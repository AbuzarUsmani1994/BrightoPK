    function ConvertDateFormat(DateFormat) {
        var re = /\/Date\(([0-9]*)\)\//;
        var m = DateFormat.match(re);
        if (m) { return new Date(parseInt(DateFormat.substr(6))); }
        else { return "-" };
    }

