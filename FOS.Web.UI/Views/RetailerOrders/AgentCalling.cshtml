$.ajax({
    type: "POST",
    data: { JobID: jobID },
    url: "@Url.Action("CustomerCallDetail", "RetailerOrders")",
    dataType: 'json',
    success: function (response) {
        debugger;

        // Clear the table body
        $('#callHistoryTableBody').empty();

        // Check if response has error
        if (response.error) {
            $('#callHistoryTableBody').html('<tr><td colspan="4" style="text-align: center; padding: 20px; color: #dc3545;">' + response.error + '</td></tr>');
            return;
        }

        // Get the call history array from the response
        var callHistoryData = response.CallHistory || [];

        // Check if response is empty or has no data
        if (!callHistoryData || callHistoryData.length === 0) {
            $('#callHistoryTableBody').html('<tr><td colspan="4" style="text-align: center; padding: 20px;">No call history found</td></tr>');
            return;
        }

        // Populate the table with call history data
        $.each(callHistoryData, function(index, call) {
            // Determine rating color
            var ratingColor = "#555"; // Default color
            var ratingText = call.Rating || "-";

            if (ratingText && ratingText !== "-") {
                var ratingLower = ratingText.toLowerCase();
                if (ratingLower.includes("excellent") || ratingLower.includes("good") || ratingLower.includes("high")) {
                    ratingColor = "#28a745";
                } else if (ratingLower.includes("average") || ratingLower.includes("medium")) {
                    ratingColor = "#ffc107";
                } else if (ratingLower.includes("poor") || ratingLower.includes("low") || ratingLower.includes("bad")) {
                    ratingColor = "#dc3545";
                }
            }

            // Format date if needed
            var callDate = call.CallDate || "-";

            // Create table row
            var row = '<tr>' +
                '<td style="padding: 10px; font-size: 13px;">' + callDate + '</td>' +
                '<td style="padding: 10px; font-size: 13px;">' + (call.CallerName || "-") + '</td>' +
                '<td style="padding: 10px; font-size: 13px;">' +
                    '<span style="color: ' + ratingColor + '; font-weight: 600;">' + ratingText + '</span>' +
                '</td>' +
                '<td style="padding: 10px; font-size: 13px;">' + (call.CallRemarks || "-") + '</td>' +
            '</tr>';

            $('#callHistoryTableBody').append(row);
        });

        // Optional: Add summary row if needed
        if (callHistoryData.length > 0) {
            var summaryRow = '<tr style="background-color: #f8f9fa;">' +
                '<td colspan="4" style="padding: 8px 10px; font-size: 12px; text-align: right; color: #555;">' +
                '<strong>Total Calls: ' + callHistoryData.length + '</strong>' +
                '</td>' +
            '</tr>';
            $('#callHistoryTableBody').append(summaryRow);
        }

    },
    error: function (xhr, status, error) {
        console.error("Error loading call history:", error);
        $('#callHistoryTableBody').html('<tr><td colspan="4" style="text-align: center; padding: 20px; color: #dc3545;">Error loading call history</td></tr>');
        alertify.error("Error loading call history");
    }
});

