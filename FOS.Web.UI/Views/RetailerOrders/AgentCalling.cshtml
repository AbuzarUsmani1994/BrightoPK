                        var month = monthNames[currentTime.getMonth()];
                        var day = currentTime.getDate("DD");
                        var year = currentTime.getFullYear();
                        var date = month + " " + day + " " + year;

                        if (isNaN(year)) {
                            $('#visitedDate').text("-");
                        }
                        else {
                            $('#visitedDate').text(date);
                        }

