@model FOS.Shared.JobsData

@{
    ViewBag.Title = "Jobs";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<style>
    #preview {
        position: absolute;
        border: 1px solid #ccc;
        background: #333;
        padding: 1px;
        display: none;
        color: #fff;
        z-index: 3000;
    }
</style>
<link href='~/Content/Style/fullcalendar.min.css' rel='stylesheet' />
<link href='~/Content/Style/fullcalendar.print.min.css' rel='stylesheet' media='print' />
<script src='~/Scripts/lib/moment.min.js'></script>
<script src='~/Scripts/lib/jquery-ui.min.js'></script>
<script src='~/Scripts/lib/fullcalendar.min.js'></script>
<link href="~/Content/Style/jquery-ui.min.css" rel="stylesheet" />


<!-- BEGIN PAGE HEADER-->
<div class="row-fluid">
    <div class="span12">
        <!-- BEGIN THEME CUSTOMIZER-->
        <!-- END THEME CUSTOMIZER-->
        <!-- BEGIN PAGE TITLE & BREADCRUMB-->
        <h3 class="page-title"></h3>
        <ul class="breadcrumb">
            <li>
                <a href="#">Calling</a>
                <span class="divider">/</span>
            </li>
            <li>
                <a href="#">Agent Calling</a>
            </li>
        </ul>
        <!-- END PAGE TITLE & BREADCRUMB-->
    </div>
</div>



<!-- BEGIN EDITABLE TABLE widget-->
<div class="row-fluid">
    <div class="span12">
        <!-- BEGIN EXAMPLE TABLE widget-->
        <div class="widget green">
            <div class="widget-title">
                <h4>AgentCalling</h4>

            </div>

            <div class="container" style="margin-top:2px;">
                <div class="row">
                    <form class="form-inline">
                        <label class="control-label" style="display:inline">Starting*</label>
                        <input class="text-box single-line" id="StartingDate1" name="StartingDate1" style="height: 22px; width: 180px; margin-bottom: 0px;">
                        <label class="control-label" style="display:inline">Ending*</label>
                        <input class="text-box single-line" id="StartingDate2" name="StartingDate2" style="height: 22px; width: 180px; margin-bottom: 0px;">




                        <label class="control-label">Head *</label>

                        @Html.DropDownListFor(model => model.RegionalHeadID, new SelectList(Model.RegionalHead, "ID", "Name"), new { @class = "" })
                        @Html.ValidationMessageFor(model => model.RegionalHeadID)



                        <label class="control-label">Data Type *</label>

                        @Html.DropDownListFor(model => model.SaleOfficerID, new SelectList(Model.SaleOfficers, "ID", "Name"), new { @class = "" })
                        @Html.ValidationMessageFor(model => model.SaleOfficerID)
                        @Html.HiddenFor(model => model.ID)
                        @Html.HiddenFor(model => model.SelectedRetailers)

                        <button type="button" id="ApplyFilter" class="btn btn-primary">
                            <i class="icon-ok icon-white" style="padding-right: 2px"></i><span style="width:50px">Apply Filter</span>
                        </button>

                    </form>
                </div>
            </div>


            <div class="widget-body">
                <div>
                    <div class="clearfix">
                        @*<div class="control-group" style="margin-bottom: 14px; display:inline">
                                <label class="control-label" style="display:inline">Starting Date *</label>
                                <div class="controls" style="display:inline">
                                    <input class="text-box single-line" id="StartingDate1" name="StartingDate1" style="height: 22px; width: 202px; margin-bottom: 0px;">
                                </div>
                            </div>*@

                        @*<div class="control-group" style="margin-bottom: 14px; display:inline">
                                <label class="control-label" style="display:inline">Ending Date *</label>
                                <div class="controls" style="display:inline">
                                    <input class="text-box single-line" id="StartingDate2" name="StartingDate2" style="height: 22px; width: 202px; margin-bottom: 0px;">
                                </div>
                            </div>*@



                        @*<div class="control-group" style="margin-bottom: 14px; display:inline">
                                <label class="control-label" style="display:inline">Sales Officer *</label>
                                <div class="controls" style="display:inline">
                                    @Html.DropDownListFor(model => model.SaleOfficerID, new SelectList(Model.SaleOfficer, "ID", "Name"), new { @class = "" })

                                </div>
                            </div>*@
                        @*<div class="control-group" style="margin-bottom: 14px; display:inline">
                                <button type="button" class="btn btn-success" id="btn_search">Search</button>

                            </div>*@


                        <div class="btn-group pull-right"></div>
                    </div>
                    <div class="space15"></div>
                    <table class="table table-striped table-hover table-bordered" style="width: 100%;" id="datatab">
                        <thead>
                            <tr>
                                <th></th>
                                <th></th>
                                <th></th>
                                <th style="width: 4% !important">Sr #</th>

                                <th style="width:6% !important">
                                    Visit ID
                                </th>
                                <th style="width:16% !important">
                                    Sales Officer
                                </th>


                                <th style="width:16% !important">
                                    Customer Name
                                </th>
                                <th style="width:16% !important">
                                    Customer Contact
                                </th>
                                <th style="width:10% !important">
                                    Caller Name
                                </th>
                                <th style="width:10% !important">
                                    Call Status
                                </th>

                                <th style="width:16% !important">
                                    Next Visit Date
                                </th>
                                <th style="width:16% !important">
                                    Created Date
                                </th>

                                <th style="width:10% !important">
                                    Customer Status
                                </th>

                                <th style="width:20% !important">
                                    Last Call Date
                                </th>



                                <th style="width:10% !important">Action</th>

                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
        <!-- END EXAMPLE TABLE widget-->
    </div>
</div>
<!-- END EDITABLE TABLE widget-->
<!-- Shop Modal -->
<div id="ShopModal" class="modal hide fade in" role="dialog" style="width: 95%; height: 95%; top: 2.5%; left: 2.5%; overflow-y: scroll;">
    <div class="modal-dialog" style="width: 100%; max-width: none; margin: 0;">
        <!-- Modal content-->
        <div class="modal-content" style="height: 95vh; margin: 0;">
            <div class="modal-header" style="border-bottom: 1px solid #e5e5e5; padding: 10px 15px;">
                <h4 class="modal-title" style="margin: 0; color: #333; font-weight: bold;">Customer Interaction Details</h4>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"
                        style="font-size: 30px; font-weight: bold; color: #000; opacity: 0.8; margin-top: -10px;">
                    &times;
                </button>
            </div>

            <div class="modal-body" style="max-height: 85vh; overflow-y: auto; padding: 0; display: flex;">

                <!-- Left Column: Data Entry Form -->
                <div style="width: 50%; padding: 15px; border-right: 2px solid #ddd; height: 100%; overflow-y: auto;">
                    <h3 style="color: #376892; border-bottom: 2px solid #376892; padding-bottom: 8px; margin-top: 0; margin-bottom: 20px;">
                        Data Entry Form
                    </h3>

                    <form>
                        <input type="hidden" id="JobID" name="JobID" value="" />
                        <table class="table table-bordered" style="margin-bottom: 20px; width: 100%;">
                            <tbody>
                                <tr>
                                    <td style="width: 40%; padding: 12px; font-weight: 600; background-color: #f5f9fd;">Call Date</td>
                                    <td style="width: 60%; padding: 12px;">
                                        <div class="form-group" style="margin: 0;">
                                            <div style="position: relative; display: inline-block;">
                                                <input class="text-box single-line" id="CallDate" name="CallDate"
                                                       style="height: 22px; width: 140px; margin-bottom: 0px; padding: 2px 8px; border: 1px solid #ccc; border-radius: 3px; font-size: 13px;">
                                            </div>
                                        </div>
                                        <div style="font-size: 11px; color: #718096; margin-top: 4px; margin-left: 2px;">
                                            Click calendar icon to select date
                                        </div>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding: 12px; font-weight: 600; background-color: #f5f9fd;">Customer Type</td>
                                    <td style="padding: 12px;">
                                        <div class="form-group" style="margin: 0;">
                                            <select class="form-control" id="customerType" style="width: 180px; padding: 4px 8px; font-size: 13px; height: 28px;">
                                                <option value="">Select</option>
                                                <option value="N/A">N/A</option>
                                                <option value="Owner">Owner</option>
                                                <option value="PaintContractor">Paint Contractor</option>
                                                <option value="ConstructionContractor">Construction Contractor</option>
                                            </select>
                                        </div>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding: 12px; font-weight: 600; background-color: #f5f9fd;">Construction Stage</td>
                                    <td style="padding: 12px;">
                                        <div class="form-group" style="margin: 0;">
                                            <select class="form-control" id="constructionStage" style="width: 180px; padding: 4px 8px; font-size: 13px; height: 28px;">
                                                <option value="">Select</option>
                                                <option value="N/A">N/A</option>
                                                <option value="UnderConstruction">Under Construction</option>
                                                <option value="GreyStructure">Grey Structure</option>
                                                <option value="ReadyToPaint">Ready To Paint</option>


                                            </select>
                                        </div>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding: 12px; font-weight: 600; background-color: #f5f9fd;">Site Status</td>
                                    <td style="padding: 12px;">
                                        <div class="form-group" style="margin: 0;">
                                            <select class="form-control" id="siteStatus" style="width: 180px; padding: 4px 8px; font-size: 13px; height: 28px;">
                                                <option value="">Select</option>
                                                <option value="N/A">N/A</option>
                                                <option value="ApplyingBrighto">Applying Brighto</option>
                                                <option value="Compititor">Compititor</option>
                                                <option value="YetToDecide">Yet To Decide</option>
                                                <option value="WorkOnHold">Work On Hold</option>
                                            </select>
                                        </div>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding: 12px; font-weight: 600; background-color: #f5f9fd;">Category</td>
                                    <td style="padding: 12px;">
                                        <div class="form-group" style="margin: 0;">
                                            <select class="form-control" id="category" style="width: 180px; padding: 4px 8px; font-size: 13px; height: 28px;">
                                                <option value="">Select</option>
                                                <option value="N/A">N/A</option>
                                                <option value="Prospect">Prospect</option>
                                                <option value="Complaint">Complaint</option>
                                                <option value="NotIntrested">Not Intrested</option>
                                                <option value="Satisfied">Satisfied</option>
                                                <option value="BrightoCustomer">Brighto Customer</option>
                                            </select>
                                        </div>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding: 12px; font-weight: 600; background-color: #f5f9fd;">Next Expected visit</td>
                                    <td style="padding: 12px;">
                                        <div class="form-group" style="margin: 0;">
                                            <select class="form-control" id="nextExpectedVisit" style="width: 180px; padding: 4px 8px; font-size: 13px; height: 28px;">
                                                <option value="">Select</option>
                                                <option value="N/A">N/A</option>
                                                <option value="OneWeek">One Week</option>
                                                <option value="TwoWeek">Two Week</option>
                                                <option value="ThreeWeek">Three Week</option>
                                                <option value="OneMonth">One Month</option>
                                                <option value="TwoMonth">Two Month</option>
                                                <option value="ThreeMonth">Three Month</option>
                                                <option value="NotSure">Not Sure</option>
                                                <option value="ImmediateVisitRequired">Immediate Visit Required</option>
                                            </select>
                                        </div>

                                    </td>
                                </tr>
                                @*<tr>
                                    <td style="padding: 12px; font-weight: 600; background-color: #f5f9fd;">Caller name</td>
                                    <td style="padding: 12px;">
                                        <div class="form-group" style="margin: 0;">
                                            <input type="text" class="form-control" id="callerName" style="width: 180px; padding: 4px 8px; font-size: 13px; height: 28px;">
                                        </div>
                                    </td>
                                </tr>*@
                                <tr>
                                    <td style="padding: 12px; font-weight: 600; background-color: #f5f9fd;">Nature of Call</td>
                                    <td style="padding: 12px;">
                                        <div class="form-group" style="margin: 0;">
                                            <select class="form-control" id="natureOfCall" style="width: 180px; padding: 4px 8px; font-size: 13px; height: 28px;">
                                                <option value="">Select</option>
                                                <option value="N/A">N/A</option>
                                                <option value="NotAnswering/Busy">Not Answering/ Busy</option>
                                                <option value="NotResponding">Not Responding</option>
                                                <option value="Callbacklater">Call back later</option>
                                                <option value="Wrong/incompleteData">Wrong / incomplete Data</option>
                                                <option value="WrongNumber">Wrong Number</option>
                                                <option value="Poweredoff">Powered off</option>
                                                <option value="CompleteFeedback">Complete Feedback</option>
                                                <option value="PartialFeedback">Partial Feedback</option>
                                                <option value="DoNotCall">Do Not Call</option>
                                            </select>
                                        </div>
                                    </td>
                                </tr>
                                <tr>

                                    <td style="padding: 12px; font-weight: 600; background-color: #f5f9fd;">Call Rating (1 to 10)</td>
                                    <td style="padding: 12px;">
                                        <div class="form-group" style="margin: 0;">
                                            <select class="form-control" id="callRating" style="width: 180px; padding: 4px 8px; font-size: 13px; height: 28px;">
                                                <option value="">Select</option>
                                                <option value="N/A">N/A</option>
                                                <option value="1">1 - Poor</option>
                                                <option value="2">2</option>
                                                <option value="3">3</option>
                                                <option value="4">4</option>
                                                <option value="5">5 - Average</option>
                                                <option value="6">6</option>
                                                <option value="7">7</option>
                                                <option value="8">8</option>
                                                <option value="9">9</option>
                                                <option value="10">10 - Excellent</option>
                                            </select>
                                        </div>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding: 12px; font-weight: 600; background-color: #f5f9fd;">Objections</td>
                                    <td style="padding: 12px;">
                                        <div class="form-group" style="margin: 0;">
                                            <select class="form-control" id="objections" style="width: 180px; padding: 4px 8px; font-size: 13px; height: 28px;">
                                                <option value="">Select</option>
                                                <option value="N/A">N/A</option>
                                                <option value="Pricetoohigh">Price too high</option>
                                                <option value="Productnotavailable">Product not available</option>
                                                <option value="Shadenotavailable">Shade not available</option>
                                                <option value="TechnicalSupportrequired">Technical Support required</option>
                                                <option value="DealerInfluenceonsale">Dealer Influence on sale</option>
                                            </select>
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <div style="margin-bottom: 20px;">
                            <label style="font-weight: 600; color: #376892; display: block; margin-bottom: 8px; font-size: 14px;">Caller Remarks</label>
                            <textarea class="form-control" id="callerRemarks" rows="3" style="width: 400px; padding: 8px 12px; resize: vertical; font-size: 13px;"></textarea>
                        </div>

                        <div style="text-align: center; margin-top: 20px; padding-top: 15px; border-top: 1px solid #eee;">
                            <button type="submit" class="btn btn-primary" style="padding: 6px 25px; font-weight: 600; font-size: 14px;">Submit Call Data</button>
                        </div>
                    </form>

                    <div style="margin-bottom: 20px;">
                        <label style="font-weight: 600; color: #376892; display: block; margin-bottom: 8px; font-size: 14px;">Send SMS to Customer</label>
                        <textarea class="form-control" id="sms" rows="3" style="width: 400px; height: 250px; padding: 8px 12px; resize: vertical; font-size: 13px;"></textarea>
                        <button type="submit" class="btn btn-primary" style="padding: 6px 25px; font-weight: 600; font-size: 14px;">Submit SMS</button>
                    </div>

                    <div style="margin-bottom: 20px;">
                        <label style="font-weight: 600; color: #376892; display: block; margin-bottom: 8px; font-size: 14px;">Send WhatsApp to Customer</label>
                        <textarea class="form-control" id="whatsaap" rows="6" style="width: 400px; height: 250px; padding: 8px 12px; resize: vertical; font-size: 13px;"></textarea>
                        <button type="submit" class="btn btn-primary" style="padding: 6px 25px; font-weight: 600; font-size: 14px;">Submit WhatsApp</button>
                    </div>


                </div>

                <!-- Right Column: Customer Visit Data (Read Only) -->
                <div style="width: 50%; padding: 15px; height: 100%; overflow-y: auto; background-color: #f8f9fa;">
                    <h3 style="color: #62c462; border-bottom: 2px solid #62c462; padding-bottom: 8px; margin-top: 0; margin-bottom: 20px;">
                        Customer Visit Data
                    </h3>

                    <div style="height: calc(100% - 50px);">
                        <div style="height: 100%; overflow-y: auto; padding-right: 5px;">

                            <!-- Main Customer Info Table -->
                            <table class="table table-bordered" style="margin-bottom: 20px; width: 100%;">
                                <tbody>
                                    <tr>
                                        <td style="width: 40%; padding: 12px; font-weight: 600; background-color: #e8f5e8;">VisitID</td>
                                        <td style="width: 60%; padding: 12px; background-color: #fff;">
                                            <span id="visitIdDisplay">VIS-2023-00123</span>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 12px; font-weight: 600; background-color: #e8f5e8;">CustomerID</td>
                                        <td style="padding: 12px; background-color: #fff;">
                                            <span id="customerIdDisplay">CUST-04567</span>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 12px; font-weight: 600; background-color: #e8f5e8;">CreatedDate</td>
                                        <td style="padding: 12px; background-color: #fff;">
                                            <span id="createdDateDisplay">2023-10-15</span>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 12px; font-weight: 600; background-color: #e8f5e8;">Next Visit Date</td>
                                        <td style="padding: 12px; background-color: #fff;">
                                            <span id="visitDateDisplay">2023-11-20</span>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>

                            <!-- 50/50 Split for Customer Details -->
                            <div style="display: flex; margin-bottom: 20px; gap: 15px;">
                                <!-- Left Column: Customer Info -->
                                <div style="flex: 1; background-color: #fff; border: 1px solid #ddd; border-radius: 4px; padding: 15px;">
                                    <h5 style="color: #376892; border-bottom: 1px solid #eee; padding-bottom: 8px; margin-top: 0; margin-bottom: 15px;">
                                        Customer Information
                                    </h5>

                                    <div style="margin-bottom: 12px;">
                                        <label style="font-weight: 600; font-size: 13px; color: #555; display: block; margin-bottom: 4px;">Owner Name</label>
                                        <div style="padding: 8px 10px; background-color: #f9f9f9; border-radius: 3px; border: 1px solid #eee;">
                                            <span id="ownerNameDisplay">John Smith</span>
                                        </div>
                                    </div>

                                    <div style="margin-bottom: 12px;">
                                        <label style="font-weight: 600; font-size: 13px; color: #555; display: block; margin-bottom: 4px;">Customer Name</label>
                                        <div style="padding: 8px 10px; background-color: #f9f9f9; border-radius: 3px; border: 1px solid #eee;">
                                            <span id="customerNameDisplay">Smith Construction Co.</span>
                                        </div>
                                    </div>

                                    <div style="margin-bottom: 12px;">
                                        <label style="font-weight: 600; font-size: 13px; color: #555; display: block; margin-bottom: 4px;">Mobile No</label>
                                        <div style="padding: 8px 10px; background-color: #f9f9f9; border-radius: 3px; border: 1px solid #eee;">
                                            <span id="mobileNoDisplay">+1 (555) 123-4567</span>
                                        </div>
                                    </div>

                                    <div style="margin-bottom: 12px;">
                                        <label style="font-weight: 600; font-size: 13px; color: #555; display: block; margin-bottom: 4px;">SaleOfficer Name</label>
                                        <div style="padding: 8px 10px; background-color: #f9f9f9; border-radius: 3px; border: 1px solid #eee;">
                                            <span id="saleOfficerDisplay">Michael Johnson</span>
                                        </div>
                                    </div>
                                </div>

                                <!-- Right Column: Business Info -->
                                <div style="flex: 1; background-color: #fff; border: 1px solid #ddd; border-radius: 4px; padding: 15px;">
                                    <h5 style="color: #62c462; border-bottom: 1px solid #eee; padding-bottom: 8px; margin-top: 0; margin-bottom: 15px;">
                                        Business Information
                                    </h5>

                                    <div style="margin-bottom: 12px;">
                                        <label style="font-weight: 600; font-size: 13px; color: #555; display: block; margin-bottom: 4px;">Competitors</label>
                                        <div style="padding: 8px 10px; background-color: #f9f9f9; border-radius: 3px; border: 1px solid #eee;">
                                            <span id="competitorsDisplay">ABC Paints, XYZ Coatings</span>
                                        </div>
                                    </div>

                                    <div style="margin-bottom: 12px;">
                                        <label style="font-weight: 600; font-size: 13px; color: #555; display: block; margin-bottom: 4px;">Business Status</label>
                                        <div style="padding: 8px 10px; background-color: #f9f9f9; border-radius: 3px; border: 1px solid #eee;">
                                            <span id="businessStatusDisplay" style="color: #28a745; font-weight: 600;">Active</span>
                                        </div>
                                    </div>

                                    <div style="margin-bottom: 12px;">
                                        <label style="font-weight: 600; font-size: 13px; color: #555; display: block; margin-bottom: 4px;">Estimated Value</label>
                                        <div style="padding: 8px 10px; background-color: #f9f9f9; border-radius: 3px; border: 1px solid #eee; color: #28a745; font-weight: 600;">
                                            <span id="estimatedValueDisplay">$50,000</span>
                                        </div>
                                    </div>

                                    <div style="margin-bottom: 12px;">
                                        <label style="font-weight: 600; font-size: 13px; color: #555; display: block; margin-bottom: 4px;">Site Won</label>
                                        <div style="padding: 8px 10px; background-color: #f0f8ff; border-radius: 3px; border: 1px solid #cce5ff;">
                                            <span id="siteWonDisplay">Pending</span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- 50/50 Split for Address and Project Details -->
                            <div style="display: flex; margin-bottom: 20px; gap: 15px;">
                                <!-- Left Column: Address -->
                                <div style="flex: 1; background-color: #fff; border: 1px solid #ddd; border-radius: 4px; padding: 15px;">
                                    <h5 style="color: #376892; border-bottom: 1px solid #eee; padding-bottom: 8px; margin-top: 0; margin-bottom: 15px;">
                                        Address & Location
                                    </h5>

                                    <div style="margin-bottom: 12px;">
                                        <label style="font-weight: 600; font-size: 13px; color: #555; display: block; margin-bottom: 4px;">Full Address</label>
                                        <div style="padding: 10px; background-color: #f9f9f9; border-radius: 3px; border: 1px solid #eee; min-height: 80px;">
                                            <span id="addressDisplay">123 Main Street, Suite 400<br>New York, NY 10001<br>United States</span>
                                        </div>
                                    </div>

                                    <div style="margin-bottom: 12px;">
                                        <label style="font-weight: 600; font-size: 13px; color: #555; display: block; margin-bottom: 4px;">Plot Size</label>
                                        <div style="padding: 8px 10px; background-color: #f9f9f9; border-radius: 3px; border: 1px solid #eee;">
                                            <span id="plotSizeDisplay">5000 sq ft</span>
                                        </div>
                                    </div>
                                </div>

                                <!-- Right Column: Project Details -->
                                <div style="flex: 1; background-color: #fff; border: 1px solid #ddd; border-radius: 4px; padding: 15px;">
                                    <h5 style="color: #62c462; border-bottom: 1px solid #eee; padding-bottom: 8px; margin-top: 0; margin-bottom: 15px;">
                                        Project Details
