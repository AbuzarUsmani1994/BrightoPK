@model FOS.Shared.JobsData

@{
    ViewBag.Title = "Jobs";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<style>
    #preview {
        position: absolute;
        border: 1px solid #ccc;
        background: #333;
        padding: 1px;
        display: none;
        color: #fff;
        z-index: 3000;
    }
</style>
<link href='~/Content/Style/fullcalendar.min.css' rel='stylesheet' />
<link href='~/Content/Style/fullcalendar.print.min.css' rel='stylesheet' media='print' />
<script src='~/Scripts/lib/moment.min.js'></script>
<script src='~/Scripts/lib/jquery-ui.min.js'></script>
<script src='~/Scripts/lib/fullcalendar.min.js'></script>
<link href="~/Content/Style/jquery-ui.min.css" rel="stylesheet" />


<!-- BEGIN PAGE HEADER-->
<div class="row-fluid">
    <div class="span12">
        <!-- BEGIN THEME CUSTOMIZER-->
        <!-- END THEME CUSTOMIZER-->
        <!-- BEGIN PAGE TITLE & BREADCRUMB-->
        <h3 class="page-title"></h3>
        <ul class="breadcrumb">
            <li>
                <a href="#">KPIS</a>
                <span class="divider">/</span>
            </li>
            <li>
                <a href="#">SO Wise KPIS</a>
            </li>
        </ul>
        <!-- END PAGE TITLE & BREADCRUMB-->
    </div>
</div>




<!-- BEGIN EDITABLE TABLE widget-->
<div class="row-fluid">
    <style>
        .form-column {
            padding: 5px 10px !important;
            margin: 0 !important;
        }

        .table-column {
            padding: 5px 10px !important;
            margin: 0 !important;
            margin-top: -10px !important; /* Adjust this value if needed */
        }

        .control-group {
            margin-bottom: 6px !important; /* Reduce spacing between fields */
        }
    </style>

    <div class="row-fluid">
        <!-- LEFT COLUMN -->
        <div class="span4 form-column">

            <div class="control-group">
                <label class="control-label">Starting Date *</label>
                <div class="controls">
                    <input class="text-box single-line" id="StartingDate1" name="StartingDate1"
                           style="height: 22px; width: 202px;">
                </div>
            </div>

            <div class="control-group">
                <label class="control-label">Ending Date *</label>
                <div class="controls">
                    <input class="text-box single-line" id="StartingDate2" name="StartingDate2"
                           style="height: 22px; width: 202px;">
                </div>
            </div>

            <div class="control-group">
                <label class="control-label">Select Head *</label>
                <div class="controls">
                    @Html.DropDownListFor(model => model.RegionalHeadID, new SelectList(Model.RegionalHead, "ID", "Name"))
                    @Html.ValidationMessageFor(model => model.RegionalHeadID)
                    @Html.HiddenFor(model => model.HiddenRegionalHeadID)
                </div>
            </div>

            <div class="control-group">
                <label class="control-label">Sales Officer *</label>
                <div class="controls">
                    @Html.DropDownListFor(model => model.SaleOfficerID, new SelectList(Model.SaleOfficer, "ID", "Name"))
                    @Html.ValidationMessageFor(model => model.SaleOfficerID)
                    @Html.HiddenFor(model => model.ID)
                    @Html.HiddenFor(model => model.SelectedRetailers)
                </div>
            </div>

            <div class="control-group">
                <label class="control-label">Business Segment *</label>
                <div class="controls">
                    @Html.DropDownListFor(model => model.SegmentID, new SelectList(Model.BusinessSegments, "ID", "Name"))
                    @Html.ValidationMessageFor(model => model.SegmentID)
                </div>
            </div>

            <div class="control-group">
                <label class="control-label">Role *</label>
                <div class="controls">
                    @Html.DropDownListFor(model => model.SORoleID, new SelectList(Model.Roles, "ID", "Name"))
                    @Html.ValidationMessageFor(model => model.SORoleID)
                </div>
            </div>

            <div class="form-actions" style="padding-left: 120px; margin-top: 15px;">
                <button type="submit" id="btnNew" class="btn btn-primary">
                    <i class="icon-ok icon-white" style="padding-right: 8px"></i>Add KPI
                </button>
            </div>

        </div>

        <!-- RIGHT COLUMN -->
        <div class="span8 table-column">
            <div class="table-responsive" style="border: 1px solid #ddd; border-radius: 4px;">
                <table class="table table-bordered table-hover" style="margin-bottom: 0;">
                    <thead class="table-light" style="background: #f5f5f5;">
                        <tr>
                            <th style="width: 50%">Focus Area</th>
                            <th style="width: 25%">Target Value</th>
                            <th style="width: 25%">Target %age</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.focusArea != null && Model.focusArea.Count > 0)
                        {
                            for (int i = 0; i < Model.focusArea.Count; i++)
                            {
                                <tr style="@(i % 2 == 0 ? "background:#f9f9f9" : "background:white")">
                                    <td style="padding: 10px; font-weight: 600; color: #376892;">
                                        <span class="focus-area-name">@Model.focusArea[i].Name</span>
                                    </td>
                                    <td style="padding: 6px;">
                                        <input type="text"
                                               class="form-control target-value"
                                               style="width: 100%; height: 28px; padding: 4px;"
                                               placeholder="Enter value">
                                    </td>
                                    <td style="padding: 6px;">
                                        <input type="text"
                                               class="form-control target-percentage"
                                               style="width: 100%; height: 28px; padding: 4px;"
                                               placeholder="Enter %">
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="text-center" style="padding: 20px;">
                                    <i class="icon-warning-sign"></i> No focus areas available
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot style="background: #f0f0f0;">
                        <tr>
                            <td style="padding: 10px; text-align: right; font-weight: bold;">Total:</td>
                            <td style="padding: 10px; text-align: center;">
                                <span id="totalTargetValue">0</span>
                            </td>
                            <td style="padding: 10px; text-align: center;">
                                <span id="totalTargetPercentage">0%</span>
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

    <div class="space15"></div>
    <table class="table table-striped table-hover table-bordered" style="width: 100%;" id="datatab">
        <thead>
            <tr>
                <th></th>
                <th></th>
                <th></th>
                <th style="width: 10% !important">Sr #</th>

                <th style="width:16% !important">
                    Sales Officer
                </th>


                <th style="width:16% !important">
                    Head Name 
                </th>
                <th style="width:16% !important">
                    Business Segment Name
                </th>
                <th style="width:16% !important">
                   Role
                </th>

                <th style="width:10% !important">Action</th>

            </tr>
        </thead>
        <tbody></tbody>
    </table>

</div>
<!-- END EDITABLE TABLE widget-->
<!-- Shop Modal -->
<div id="ShopModal" class="modal hide fade in" role="dialog" style="width: 71%;height: 100%;top: 4%;left: 15%;overflow-y:scroll;">

    <div class="modal-dialog">

        <!-- Modal content-->
        <div class="modal-content">
            <div class="modal-header" style="border-bottom: 1px solid #e5e5e5;">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"
                        style="font-size: 30px; font-weight: bold; color: #000; opacity: 0.8;">
                    &times;
                </button>
            </div>

            <div class="modal-body" style="max-height: 80vh; overflow-y: auto;">

                <div class="span12">

                    <h2 style="margin-top: -10px;text-align:center;color: #62c462;font-weight: bolder;border-bottom: 1px solid #62c462;border-top: 1px solid #62c462;padding-bottom: 10px;padding-top: 10px;" id="jobstatus">Claim Details</h2>

                    <div class="span12" style="padding:5px">

                        <table class="table table-striped table-hover table-bordered">
                            <thead>
                                <tr>
                                    <th style="text-align:center;background: #545454;color: white;" colspan="2">Detail</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td style="padding: 19px  0px 19px  5px;"><span style="margin: 0px 0px 0px 0px;font-weight: 600;color: #376892;">Sales Officer</span></td>
                                    <td style="padding: 19px  0px 19px  5px;"><span id="saleOfficer" style=""></span></td>
                                </tr>

                                <tr>
                                    <td style="padding: 19px  0px 19px  5px;"><span style="margin: 0px 0px 0px 0px;font-weight: 600;color: #376892;">Customer Name/Trade Party Name</span></td>
                                    <td style="padding: 19px  0px 19px  5px;"><span id="SchoolShopName" style=""></span></td>
                                </tr>

                                <tr>
                                    <td style="padding: 19px  0px 19px  5px;"><span style="margin: 0px 0px 0px 0px;font-weight: 600;color: #376892;">Claim Picture</span></td>
                                    <td style="padding: 19px  0px 19px  5px;"><span id="ClaimPicture" style=""></span></td>
                                </tr>



                                <tr>
                                    <td style="padding: 18px  0px 18px  5px;"><span style="margin: 0px 0px 0px 0px;font-weight: 600;color: #376892;">Visted Date</span></td>
                                    <td style="padding: 18px  0px 18px  5px;"><span id="visitedDate" style=""></span></td>
                                </tr>

                            </tbody>
                        </table>

                    </div>





                    <div class="span12" style="padding-top: 10px;">
                        <table class="table table-bordered table-hover" id="tblApprovals" style="border: 2px solid #20c997;">
                            <!-- Teal border -->
                            <thead style="background: linear-gradient(to right, #17a2b8, #20c997); color: white;">
                                <!-- Aquatic gradient -->
                                <tr>
                                    <th colspan="4" style="text-align: center; font-size: 18px; font-weight: bold;">
                                        Claim Approvals History
                                    </th>
                                </tr>
                                <tr style="text-align: center;">
                                    <th style="width: 14.28%;">Approved By</th>
                                    <th style="width: 14.28%;">Approved Status</th>
                                    <th style="width: 14.28%;">Approved At</th>
                                    <th style="width: 14.28%;">Remarks</th>

                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>







                </div>

            </div>

        </div>

    </div>

</div>
<!-- END Shop Modal -->
<!-- Modal to show full image -->
<!-- Full Image Modal -->
<style>
    /* Soft backdrop */
    .modal-backdrop {
        background-color: rgba(0, 0, 0, 0.75);
    }

    /* Modal styling */
    #imageModal .modal-content {
        border-radius: 10px;
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.4);
        background-color: #ffffff;
    }

    #imageModal .modal-header {
        background-color: #376892;
        color: white;
        border-top-left-radius: 10px;
        border-top-right-radius: 10px;
        padding: 1rem 1.25rem;
    }

        #imageModal .modal-header .close {
            color: white;
            opacity: 1;
            font-size: 1.5rem;
        }

    #imageModal .modal-body img {
        max-width: 100%;
        max-height: 80vh;
        border-radius: 8px;
        border: 4px solid #f1f1f1;
        transition: transform 0.3s ease, border-color 0.3s ease;
    }

        #imageModal .modal-body img:hover {
            transform: scale(1.02);
            border-color: #376892;
        }
</style>

<!-- Modal -->
<div id="imageModal" class="modal fade" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-image" style="margin-right: 8px;"></i> Claim Full Image
                </h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body text-center">
                <img id="fullImage" src="" alt="Claim Image" />
            </div>
        </div>
    </div>
</div>



