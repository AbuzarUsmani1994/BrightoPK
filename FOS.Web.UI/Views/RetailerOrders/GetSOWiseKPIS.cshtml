        $("#btnNew").click(function (e) {
    e.preventDefault(); // Prevent default form submission

    // Validate required fields
    if (!validateForm()) {
        return false;
    }

    // Collect table data with focus area names
    var focusAreasData = [];
    var hasError = false;
    var errorMessages = [];

    $('tbody tr').each(function(index) {
        var $row = $(this);
        var focusName = $row.find('.focus-area-name').text();
        var targetValue = $row.find('.target-value').val();
        var targetPercentage = $row.find('.target-percentage').val();

        // Skip empty rows if needed, or validate
        if (focusName) {
            // Validate if both values are provided (if you want both required)
            if ((targetValue && !targetPercentage) || (!targetValue && targetPercentage)) {
                hasError = true;
                errorMessages.push(focusName + ' requires both Target Value and Target %age');
            }

            // Add to collection (even if empty, depending on your requirement)
            focusAreasData.push({
                FocusAreaName: focusName,
                TargetValue: targetValue || "0",
                TargetPercentage: targetPercentage || "0"
            });
        }
    });

    if (hasError) {
        alertify.error('Please fix the following errors:\n' + errorMessages.join('\n'));
        return false;
    }

    // Collect all form data
    var kpiData = {
        // Basic form data
        StartingDate1: $('#StartingDate1').val(),
        StartingDate2: $('#StartingDate2').val(),
        RegionalHeadID: $('#RegionalHeadID').val(),
        SaleOfficerID: $('#SaleOfficerID').val(),
        SegmentID: $('#SegmentID').val(),
        SORoleID: $('#SORoleID').val(),

        // Focus areas data with names
        FocusAreas: focusAreasData,

        // Security token
        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
    };

    // Show loading state
    var $btn = $(this);
    var originalText = $btn.html();
    $btn.html('<i class="icon-spinner icon-spin"></i> Adding KPI...').prop('disabled', true);

    console.log('Sending data to server:', kpiData); // For debugging

    // Send data to server
    $.ajax({
        url: '@Url.Action("AddKPI", "RetailerOrders")',
        type: 'POST',
        data: JSON.stringify(kpiData),
        contentType: 'application/json',
        dataType: 'json',
        success: function(response) {
            if (response.success) {
                alertify.success('KPI added successfully!');
                // Optionally reset form
                resetForm();
            } else {
                alertify.error('Error: ' + response.message);
            }
        },
        error: function(xhr, status, error) {
            alertify.error('Failed to add KPI. Please try again.');
            console.error('Error details:', error, xhr.responseText);
        },
        complete: function() {
            $btn.html(originalText).prop('disabled', false);
        }
    });
});

// Form validation
function validateForm() {
    var isValid = true;
    var errors = [];

    // Clear previous error highlights
    $('.control-group').removeClass('error');

    // Validate dates
    if (!$('#StartingDate1').val()) {
        errors.push('Starting Date is required');
        $('#StartingDate1').closest('.control-group').addClass('error');
        isValid = false;
    }

    if (!$('#StartingDate2').val()) {
        errors.push('Ending Date is required');
        $('#StartingDate2').closest('.control-group').addClass('error');
        isValid = false;
    }

    // Validate dropdowns
    var dropdowns = [
        { id: '#RegionalHeadID', name: 'Head' },
        { id: '#SaleOfficerID', name: 'Sales Officer' },
        { id: '#SegmentID', name: 'Business Segment' },
        { id: '#SORoleID', name: 'Role' }
    ];

    dropdowns.forEach(function(dropdown) {
        if (!$(dropdown.id).val()) {
            errors.push(dropdown.name + ' is required');
            $(dropdown.id).closest('.control-group').addClass('error');
            isValid = false;
        }
    });

    // Validate at least one focus area has data (optional)
    var hasData = false;
    $('.target-value, .target-percentage').each(function() {
        if ($(this).val().trim()) {
            hasData = true;
            return false; // Break the loop
        }
    });

    if (!hasData) {
        errors.push('Please enter target values for at least one focus area');
        isValid = false;
    }

    if (!isValid) {
        alertify.error('Please fix the following errors:\n\n' + errors.join('\n'));
    }

    return isValid;
}

// Calculate totals
function calculateTotals() {
    var totalValue = 0;
    var totalPercentage = 0;

    $('.target-value').each(function() {
        var val = parseFloat($(this).val()) || 0;
        totalValue += val;
    });

    $('.target-percentage').each(function() {
        var perc = parseFloat($(this).val()) || 0;
        totalPercentage += perc;
    });

    $('#totalTargetValue').text(totalValue.toLocaleString());
    $('#totalTargetPercentage').text(totalPercentage.toFixed(1) + '%');
}

// Update totals on input
$(document).on('input', '.target-value, .target-percentage', function() {
    calculateTotals();
});

// Reset form
function resetForm() {
    // Clear form inputs
    $('#StartingDate1, #StartingDate2').val('');
    $('.target-value, .target-percentage').val('');
    calculateTotals();

    // Optionally reset dropdowns to first option
    $('#RegionalHeadID, #SaleOfficerID, #SegmentID, #SORoleID').val('');
}

