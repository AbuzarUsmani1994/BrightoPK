<!-- Status Update Modal -->
<button id="statusUpdateModalButton" data-toggle="modal" data-target="#statusUpdateModal" style="display:none"></button>
<!-- Status Update Modal -->
<div id="statusUpdateModal" class="modal fade" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-md" role="document">
        <div class="modal-content" style="border-radius: 10px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.2);">
            <div class="modal-header" style="background: linear-gradient(135deg, #376892 0%, #2c3e50 100%); color: white; padding: 15px 20px; border-bottom: none;">
                <h5 class="modal-title" style="font-weight: 600;">
                    <i class="fas fa-edit" style="margin-right: 10px;"></i> Update Claim Status
                </h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"
                        style="color: white; opacity: 0.8; font-size: 1.5rem; padding: 0; margin: 0;">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body" style="padding: 25px;">
                <input type="hidden" id="claimIdForStatus" />

                <div class="form-group mb-4">
                    <label for="statusSelect" class="form-label" style="font-weight: 600; color: #376892; margin-bottom: 8px;">
                        <i class="fas fa-tag" style="margin-right: 8px;"></i>Status *
                    </label>
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text" style="background-color: #f8f9fa;">
                                <i class="fas fa-caret-down"></i>
                            </span>
                        </div>
                        <select class="form-control" id="statusSelect"
                                style="height: 45px; border-left: 0; border-radius: 0 4px 4px 0;">
                            <option value="" disabled selected>Select Status</option>
                            <option value="Pending" class="text-warning">Pending</option>
                            <option value="Approved" class="text-success">Approved</option>
                        </select>
                    </div>
                    <small class="text-danger mt-1" id="statusError" style="display: none;">
                        <i class="fas fa-exclamation-circle"></i> Please select a status
                    </small>
                </div>

                <div class="form-group mb-4">
                    <label for="remarksText" class="form-label" style="font-weight: 600; color: #376892; margin-bottom: 8px;">
                        <i class="fas fa-comment-alt" style="margin-right: 8px;"></i>Remarks *
                    </label>
                    <div class="position-relative">
                        <textarea class="form-control" id="remarksText" rows="6"
                                  placeholder="Enter your remarks here..."
                                  style="resize: vertical; min-height: 150px; font-size: 14px;
                                         padding: 12px; border: 1px solid #e0e0e0;
                                         border-radius: 4px; transition: all 0.3s;"></textarea>
