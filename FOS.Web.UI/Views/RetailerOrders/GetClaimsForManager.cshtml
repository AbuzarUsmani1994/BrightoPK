@model FOS.Shared.JobsData

@{
    ViewBag.Title = "Jobs";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<style>
    #preview {
        position: absolute;
        border: 1px solid #ccc;
        background: #333;
        padding: 1px;
        display: none;
        color: #fff;
        z-index: 3000;
    }

    .btn-warning.status-update {
        background-color: #f0ad4e;
        border-color: #eea236;
    }

        .btn-warning.status-update:hover {
            background-color: #ec971f;
            border-color: #d58512;
        }

    /* Modal styling */
    #statusUpdateModal .modal-header {
        background-color: #376892;
        color: white;
        border-top-left-radius: 8px;
        border-top-right-radius: 8px;
    }

    #statusUpdateModal .close {
        color: white;
        opacity: 1;
    }

    #statusUpdateModal .modal-body {
        padding: 20px;
    }

    /* Status badges */
    .badge-success {
        background-color: #5cb85c;
    }

    .badge-warning {
        background-color: #f0ad4e;
    }

    .badge-danger {
        background-color: #d9534f;
    }

    .badge-secondary {
        background-color: #777;
    }
</style>
<link href='~/Content/Style/fullcalendar.min.css' rel='stylesheet' />
<link href='~/Content/Style/fullcalendar.print.min.css' rel='stylesheet' media='print' />
<script src='~/Scripts/lib/moment.min.js'></script>
<script src='~/Scripts/lib/jquery-ui.min.js'></script>
