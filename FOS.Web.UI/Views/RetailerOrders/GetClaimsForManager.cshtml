<!-- BEGIN PAGE HEADER-->
<div class="row-fluid">
    <div class="span12">
        <!-- BEGIN THEME CUSTOMIZER-->
        <!-- END THEME CUSTOMIZER-->
        <!-- BEGIN PAGE TITLE & BREADCRUMB-->
        <h3 class="page-title"></h3>
        <ul class="breadcrumb">
            <li>
                <a href="#">Claims</a>
                <span class="divider">/</span>
            </li>
            <li>
                <a href="#">Claims Detail</a>
            </li>
        </ul>
        <!-- END PAGE TITLE & BREADCRUMB-->
