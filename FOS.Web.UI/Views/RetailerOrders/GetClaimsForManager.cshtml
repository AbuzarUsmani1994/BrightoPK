<script>
    function ConvertDateFormat(DateFormat) {
        var re = /\/Date\(([0-9]*)\)\//;
        var m = DateFormat.match(re);
        if (m) { return new Date(parseInt(DateFormat.substr(6))); }
        else { return "-" };
    }

    $(document).ready(function () {

        $('#StartingDate1').datepicker(
              {
                  dateFormat: 'dd-M-yy',
                  changeMonth: true,
                  changeYear: true,
                  yearRange: '1950:2100'
              });

        $('#StartingDate2').datepicker(
        {
            dateFormat: 'dd-M-yy',
            changeMonth: true,
            changeYear: true,
            yearRange: '1950:2100'
        });
        $("#liJob,#liCheckJobs").addClass("active");
        GenerateDetailGrid();

        $("#saveStatusBtn").on("click", function () {
        debugger;

        var claimId = $("#claimIdForStatus").val();
        var newStatus = $("#statusSelect").val();
        var remarks = $("#remarksText").val();

        // Validation
        var isValid = true;

        if (!newStatus) {
            $("#statusError").show();
            isValid = false;
        } else {
            $("#statusError").hide();
        }

        if (!remarks) {
            $("#remarksError").show();
            isValid = false;
        } else {
            $("#remarksError").hide();
        }

        if (!isValid) {
            return;
        }

        // Show loading
        $(this).html('<i class="fas fa-spinner fa-spin"></i> Saving...').prop('disabled', true);

        // Send AJAX request
        $.ajax({
            type: "POST",
            url: "@Url.Action("UpdateClaimStatus", "Job")", // You'll need to create this action
            data: {
                claimId: claimId,
                status: newStatus,
                remarks: remarks
            },
            success: function (response) {
                $("#saveStatusBtn").html('<i class="fas fa-save"></i> Update Status').prop('disabled', false);

                if (response.success) {
                    alertify.success('Status updated successfully!');
                    $("#statusUpdateModal").modal('hide');

                    // Refresh the DataTable
                    var table = $('#datatab').DataTable();
                    table.ajax.reload(null, false); // false means don't reset paging
                } else {
                    alertify.error('Error: ' + (response.message || 'Failed to update status'));
                }
            },
            error: function () {
                $("#saveStatusBtn").html('<i class="fas fa-save"></i> Update Status').prop('disabled', false);
                alertify.error('An error occurred while updating status');
            }
        });
    });

    // Close modal reset
    $("#statusUpdateModal").on('hidden.bs.modal', function () {
        $("#saveStatusBtn").html('<i class="fas fa-save"></i> Update Status').prop('disabled', false);
    });
    });

    function showFullImage(src) {
        $('#fullImage').attr('src', src);
        $('#imageModal').modal('show');
    }

