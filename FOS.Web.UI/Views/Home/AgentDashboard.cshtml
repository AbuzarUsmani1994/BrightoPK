<div class="chart-container">
    <div style="text-align: center; margin-bottom: 20px;">
        <h3 class="chart-title">🏷️ Customer Category Distribution</h3>
    </div>
    <div id="categoryChart" style="height: 450px; width: 100%;"></div>
</div>

<script>
    window.onload = function () {
        // Enhanced color palettes
        const pieColorPalette = [
            "#FF6B6B", "#4ECDC4", "#45B7D1", "#96CEB4", "#FFEAA7",
            "#DDA0DD", "#98D8C8", "#F7B731", "#5D9BEC", "#F3A683",
            "#778BEB", "#E77F67", "#CF6F8D", "#88B04B", "#FFC312"
        ];

        const barColorPalette = {
            customerType: ["#667eea", "#764ba2", "#f093fb", "#4facfe", "#00f2fe"],
            constructionStage: ["#fa709a", "#fee140", "#f6d365", "#fda085", "#84fab0"],
            siteStatus: ["#a8edea", "#fed6e3", "#ff9a9e", "#fecfef", "#a1c4fd"],
            category: ["#ffecd2", "#fcb69f", "#ff9a9e", "#a6c1ee", "#fbc2eb"]
        };

        // Helper function to calculate total
        function calculateTotal(data) {
            return data.reduce((sum, item) => sum + item.count, 0);
        }

        // Helper function to format number with commas
        function formatNumber(num) {
            return num.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",");
        }

        // ==================== 1. PIE CHART - Nature of Call ====================
        var natureOfCallData = @Html.Raw(ViewBag.NatureOfCallData);

        if (natureOfCallData && natureOfCallData.length > 0) {
            var pieChartData = [];
            var totalCalls = calculateTotal(natureOfCallData);

            natureOfCallData.forEach(function (item, index) {
                pieChartData.push({
                    y: item.count,
                    label: item.label,
                    color: pieColorPalette[index % pieColorPalette.length],
                    exploded: index === 0 // Explode the first slice for emphasis
                });
            });

            var pieChart = new CanvasJS.Chart("natureOfCallChart", {
                backgroundColor: "transparent",
                animationEnabled: true,
                animationDuration: 1500,
                exportEnabled: true,
                exportFileName: "NatureOfCall_Report",
                theme: "light2",
                title: {
                    text: `Total Calls: ${formatNumber(totalCalls)}`,
                    fontSize: 16,
                    fontColor: "#7f8c8d",
                    fontWeight: "normal",
                    padding: 10
                },
                subtitles: [{
                    text: "Click on slices to see details",
                    fontSize: 12,
                    fontColor: "#95a5a6",
                    fontStyle: "italic"
                }],
                data: [{
                    type: "pie",
                    showInLegend: true,
                    legendText: "{label}",
                    legendMarkerType: "circle",
                    toolTipContent: "<b>{label}</b><br/>📞 Calls: {y}<br/>📊 Percentage: {percentage}%",
                    indexLabel: "{percentage}%",
                    indexLabelPlacement: "inside",
                    indexLabelFontSize: 14,
                    indexLabelFontColor: "#fff",
                    indexLabelFontWeight: "bold",
                    indexLabelBackgroundColor: "rgba(0,0,0,0.5)",
                    indexLabelBorderRadius: 5,
                    indexLabelPadding: 5,
                    startAngle: 90,
                    dataPoints: pieChartData,
                    click: function (e) {
                        var percentage = ((e.dataPoint.y / totalCalls) * 100).toFixed(2);
                        Swal.fire({
                            title: e.dataPoint.label,
                            html: `
                                <div style="text-align: center;">
                                    <h3>📞 ${formatNumber(e.dataPoint.y)} Calls</h3>
                                    <p style="font-size: 18px;">${percentage}% of total calls</p>
                                    <div class="progress-bar" style="width: ${percentage}%; background: ${e.dataPoint.color};"></div>
                                </div>
                            `,
                            icon: 'info',
                            confirmButtonColor: e.dataPoint.color,
                            confirmButtonText: 'Close'
                        });
                    }
                }],
                legend: {
                    cursor: "pointer",
                    fontSize: 13,
                    fontColor: "#2c3e50",
                    verticalAlign: "right",
                    horizontalAlign: "right",
                    itemclick: function (e) {
                        if (typeof (e.dataSeries.visible) === "undefined" || e.dataSeries.visible) {
                            e.dataSeries.visible = false;
                        } else {
                            e.dataSeries.visible = true;
                        }
                        pieChart.render();
                    }
                }
            });
            pieChart.render();
        }

        // ==================== 2. BAR CHART - Customer Type ====================
        var customerTypeData = @Html.Raw(ViewBag.CustomerTypeData);

        if (customerTypeData && customerTypeData.length > 0) {
            var customerBarData = customerTypeData.map(function(item, index) {
                return {
                    label: item.label,
                    y: item.count,
                    color: barColorPalette.customerType[index % barColorPalette.customerType.length]
                };
            });

            var customerChart = new CanvasJS.Chart("customerTypeChart", {
                backgroundColor: "transparent",
                animationEnabled: true,
                animationDuration: 1500,
                exportEnabled: true,
                exportFileName: "CustomerType_Report",
                theme: "light2",
                title: {
                    text: `Total Customers: ${formatNumber(calculateTotal(customerTypeData))}`,
                    fontSize: 16,
                    fontColor: "#7f8c8d",
                    fontWeight: "normal"
                },
                axisX: {
                    title: "Customer Type",
                    titleFontSize: 14,
                    titleFontColor: "#2c3e50",
                    titleFontWeight: "bold",
                    labelAngle: -30,
                    labelFontSize: 12,
                    labelFontColor: "#2c3e50",
                    labelFontWeight: "bold",
                    lineColor: "#bdc3c7",
                    tickColor: "#bdc3c7"
                },
                axisY: {
                    title: "Number of Calls",
                    titleFontSize: 14,
                    titleFontColor: "#2c3e50",
                    titleFontWeight: "bold",
                    gridThickness: 1,
                    gridColor: "#ecf0f1",
                    lineColor: "#bdc3c7",
                    tickColor: "#bdc3c7",
                    minimum: 0,
                    labelFormatter: function(e) {
                        return formatNumber(e.value);
                    }
                },
                data: [{
                    type: "column",
                    dataPoints: customerBarData,
                    cornerRadius: 8,
                    toolTipContent: "<b>{label}</b><br/>📞 Calls: {y}<br/>📊 Percentage: <b>#percent#</b>",
                    click: function (e) {
                        var total = calculateTotal(customerTypeData);
                        var percentage = ((e.dataPoint.y / total) * 100).toFixed(2);
                        Swal.fire({
                            title: e.dataPoint.label,
                            html: `
                                <div style="text-align: center;">
                                    <h3>📞 ${formatNumber(e.dataPoint.y)} Calls</h3>
                                    <p>${percentage}% of total customers</p>
                                </div>
                            `,
                            icon: 'success',
                            confirmButtonColor: e.dataPoint.color
                        });
                    }
                }]
            });
            customerChart.render();
        }

        // ==================== 3. BAR CHART - Construction Stage ====================
        var constructionStageData = @Html.Raw(ViewBag.ConstructionStageData);

        if (constructionStageData && constructionStageData.length > 0) {
            var constructionBarData = constructionStageData.map(function(item, index) {
                return {
                    label: item.label,
                    y: item.count,
                    color: barColorPalette.constructionStage[index % barColorPalette.constructionStage.length]
                };
            });

            var constructionChart = new CanvasJS.Chart("constructionStageChart", {
                backgroundColor: "transparent",
                animationEnabled: true,
                animationDuration: 1500,
                exportEnabled: true,
                exportFileName: "ConstructionStage_Report",
                theme: "light2",
                title: {
                    text: `Total Projects: ${formatNumber(calculateTotal(constructionStageData))}`,
                    fontSize: 16,
                    fontColor: "#7f8c8d",
                    fontWeight: "normal"
                },
                axisX: {
                    title: "Construction Stage",
                    titleFontSize: 14,
                    titleFontColor: "#2c3e50",
                    titleFontWeight: "bold",
                    labelAngle: -30,
                    labelFontSize: 12,
                    labelFontColor: "#2c3e50",
                    labelFontWeight: "bold"
                },
                axisY: {
                    title: "Number of Calls",
                    titleFontSize: 14,
                    titleFontColor: "#2c3e50",
                    titleFontWeight: "bold",
                    gridThickness: 1,
                    gridColor: "#ecf0f1",
                    minimum: 0,
                    labelFormatter: function(e) {
                        return formatNumber(e.value);
                    }
                },
                data: [{
                    type: "column",
                    dataPoints: constructionBarData,
                    cornerRadius: 8,
                    toolTipContent: "<b>{label}</b><br/>📞 Calls: {y}",
                    click: function (e) {
                        Swal.fire({
                            title: e.dataPoint.label,
                            text: `${formatNumber(e.dataPoint.y)} calls received`,
                            icon: 'info',
                            confirmButtonColor: e.dataPoint.color
                        });
                    }
                }]
            });
            constructionChart.render();
        }

        // ==================== 4. BAR CHART - Site Status ====================
        var siteStatusData = @Html.Raw(ViewBag.SiteStatusData);

        if (siteStatusData && siteStatusData.length > 0) {
            var siteStatusBarData = siteStatusData.map(function(item, index) {
                return {
                    label: item.label,
                    y: item.count,
                    color: barColorPalette.siteStatus[index % barColorPalette.siteStatus.length]
                };
            });

            var siteStatusChart = new CanvasJS.Chart("siteStatusChart", {
                backgroundColor: "transparent",
                animationEnabled: true,
                animationDuration: 1500,
                exportEnabled: true,
                exportFileName: "SiteStatus_Report",
                theme: "light2",
                title: {
                    text: `Total Sites: ${formatNumber(calculateTotal(siteStatusData))}`,
                    fontSize: 16,
                    fontColor: "#7f8c8d",
                    fontWeight: "normal"
                },
                axisX: {
                    title: "Site Status",
                    titleFontSize: 14,
                    titleFontColor: "#2c3e50",
                    titleFontWeight: "bold",
                    labelAngle: -30,
                    labelFontSize: 12,
                    labelFontColor: "#2c3e50",
                    labelFontWeight: "bold"
                },
                axisY: {
                    title: "Number of Calls",
                    titleFontSize: 14,
                    titleFontColor: "#2c3e50",
                    titleFontWeight: "bold",
                    gridThickness: 1,
                    gridColor: "#ecf0f1",
                    minimum: 0,
                    labelFormatter: function(e) {
                        return formatNumber(e.value);
                    }
                },
                data: [{
                    type: "column",
                    dataPoints: siteStatusBarData,
                    cornerRadius: 8,
                    toolTipContent: "<b>{label}</b><br/>📞 Calls: {y}",
                    click: function (e) {
                        Swal.fire({
                            title: e.dataPoint.label,
                            text: `${formatNumber(e.dataPoint.y)} calls for this status`,
                            icon: 'warning',
                            confirmButtonColor: e.dataPoint.color
                        });
                    }
                }]
            });
            siteStatusChart.render();
        }

        // ==================== 5. BAR CHART - Category ====================
        var categoryData = @Html.Raw(ViewBag.CategoryData);

        if (categoryData && categoryData.length > 0) {
            var categoryBarData = categoryData.map(function(item, index) {
                return {
                    label: item.label,
                    y: item.count,
                    color: barColorPalette.category[index % barColorPalette.category.length]
                };
            });

            var categoryChart = new CanvasJS.Chart("categoryChart", {
                backgroundColor: "transparent",
                animationEnabled: true,
                animationDuration: 1500,
                exportEnabled: true,
                exportFileName: "CustomerCategory_Report",
                theme: "light2",
                title: {
                    text: `Total Categories: ${formatNumber(calculateTotal(categoryData))}`,
                    fontSize: 16,
                    fontColor: "#7f8c8d",
                    fontWeight: "normal"
                },
                axisX: {
                    title: "Customer Category",
                    titleFontSize: 14,
                    titleFontColor: "#2c3e50",
                    titleFontWeight: "bold",
                    labelAngle: -30,
                    labelFontSize: 12,
                    labelFontColor: "#2c3e50",
                    labelFontWeight: "bold"
                },
                axisY: {
                    title: "Number of Calls",
                    titleFontSize: 14,
                    titleFontColor: "#2c3e50",
                    titleFontWeight: "bold",
                    gridThickness: 1,
                    gridColor: "#ecf0f1",
                    minimum: 0,
                    labelFormatter: function(e) {
                        return formatNumber(e.value);
                    }
                },
                data: [{
                    type: "column",
                    dataPoints: categoryBarData,
                    cornerRadius: 8,
                    toolTipContent: "<b>{label}</b><br/>📞 Calls: {y}",
                    click: function (e) {
                        Swal.fire({
                            title: e.dataPoint.label,
                            text: `${formatNumber(e.dataPoint.y)} calls in this category`,
                            icon: 'question',
                            confirmButtonColor: e.dataPoint.color
                        });
                    }
                }]
            });
            categoryChart.render();
        }
    }
</script>






