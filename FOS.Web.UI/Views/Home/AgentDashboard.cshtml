<style>
    .chart-container {
        background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        padding: 25px;
        margin-bottom: 30px;
        transition: all 0.3s ease;
        border: 1px solid rgba(0,0,0,0.05);
    }

        .chart-container:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 40px rgba(0,0,0,0.15);
        }

    .chart-title {
        font-size: 24px;
        font-weight: 600;
        margin-bottom: 20px;
        padding-bottom: 10px;
        border-bottom: 3px solid;
        display: inline-block;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .chart-stats {
        display: flex;
        justify-content: space-between;
        margin-top: 15px;
        padding: 10px;
        background: rgba(0,0,0,0.03);
        border-radius: 10px;
    }

    .stat-card {
        text-align: center;
        flex: 1;
        padding: 10px;
    }

    .stat-value {
        font-size: 24px;
        font-weight: bold;
        color: #2c3e50;
    }

    .stat-label {
        font-size: 12px;
        color: #7f8c8d;
        margin-top: 5px;
    }
</style>

<div class="chart-container">
    <div style="text-align: center; margin-bottom: 20px;">
        <h3 class="chart-title">📊 Nature of Call Distribution</h3>
    </div>
    <div id="natureOfCallChart" style="height: 450px; width: 100%;"></div>
</div>

<div class="chart-container">
    <div style="text-align: center; margin-bottom: 20px;">
        <h3 class="chart-title">👥 Customer Type Distribution</h3>
    </div>
    <div id="customerTypeChart" style="height: 450px; width: 100%;"></div>
</div>

<div class="chart-container">
    <div style="text-align: center; margin-bottom: 20px;">
        <h3 class="chart-title">🏗️ Construction Stage Distribution</h3>
    </div>
    <div id="constructionStageChart" style="height: 450px; width: 100%;"></div>
</div>

<div class="chart-container">
