@model FOS.Shared.JobsData

@{
    ViewBag.Title = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@*
    <link href="~/Content/Style/morris.css" rel="stylesheet" />*@

<link href="http://code.jquery.com/ui/1.10.4/themes/ui-lightness/jquery-ui.css" rel="stylesheet">
<script src="http://code.jquery.com/ui/1.10.4/jquery-ui.js"></script>

<!-- BEGIN PAGE HEADER-->
<div class="row-fluid">
    <div class="span12">
        <h3 class="page-title"></h3>
        <ul class="breadcrumb">
            <li>
                <a href="#">Graphical Dashboard</a>
            </li>
        </ul>
        <!-- END PAGE TITLE & BREADCRUMB-->
    </div>
</div>



<div class="row">
    <form class="form-inline">
        <label class="control-label" style="margin-left:40px">Region *</label>

        @Html.DropDownListFor(model => model.RegionID, new SelectList(Model.SORegions, "ID", "Name"), new { @class = "", style = "220px" })
        @Html.ValidationMessageFor(model => model.RegionID)
        @Html.HiddenFor(model => model.RegionID)


        <label class="control-label">Starting Date *</label>

        <input class="text-box single-line" id="StartingDate1" name="StartingDate1" style="height: 22px; width: 202px; margin-bottom: 0px;">


        <label class="control-label">Ending Date *</label>

        <input class="text-box single-line" id="StartingDate2" name="StartingDate2" style="height: 22px; width: 202px; margin-bottom: 0px;">



        <button type="submit" id="btnNew" class="btn btn-primary">
            <i class="icon-ok icon-white" style="padding-right: 8px"></i><span id="create">Get Dashboard</span>
        </button>

    </form>
</div>





<script src="https://canvasjs.com/assets/script/canvasjs.min.js"></script>

<div id="chartContainerForSOVisitss" style="width: auto; height: 400px;">

</div>
<div id="chartContainerForDistributorVisits" style="width: auto; height: 400px;">

</div>

<div id="ChartContainerCitywise" style="width: auto; height: 400px;">
</div>
<div id="chartContainer" style="width: auto; height: 400px;">

</div>
<div id="ChartContainerZonewise1" style="width: auto; height: 400px;">
</div>
<div id="ChartContainerZonewise2" style="width: auto; height: 400px;">
</div>
<div id="ChartContainerZoneAmountwise1" style="width: 45%; height: 400px;display: inline-block;">
</div>
<div id="ChartContainerZoneAmountwise2" style="width: 45%; height: 400px;display: inline-block;">
</div>
<div id="chartContainerForItems" style="width: auto; height: 100%;">

</div>

<script>
    window.onload = function () {

        var result = @Html.Raw(ViewBag.DataPoints3);
        debugger;

        var ColumnChartData = [];
        for (var i = 0; i < result.length; i++) {
            ColumnChartData.push(
                { y: result[i].Visits, label: result[i].SaleOfficerName }
            );
        }
        var chart = new CanvasJS.Chart("chartContainerForSOVisitss", {
            animationEnabled: true,

            title: {
                text: "Total Parties"
            },
            data: [{
                type: "pie",
                startAngle: 200,
                dataPoints: ColumnChartData
            }]
        });
        chart.render();

    var result = @Html.Raw(ViewBag.DataPoints2);
    var ColumnChartData = {};
    var regions = [];

    // Define a color mapping for ItemNames
    var colorMapping = {
        "All Purpose": "#28a745", // Green for AllPurpose
        "Trade": "#007bff",      // Blue for Trade
        "Corporate": "#fd7e14",  // Orange for Corporate
        "Housing": "#FFD700",
        // Add more item names and their corresponding colors as needed
    };

    // Loop through the result to prepare data for the chart
    for (var i = 0; i < result.length; i++) {
        var region = result[i].RegionName;
        var itemName = result[i].SaleOfficerName;
        var orders = result[i].Visits;

        // Initialize region entry if not already done
        if (!ColumnChartData[region]) {
            ColumnChartData[region] = {
                region: region,
                data: [] // This will hold item data for each region
            };
            regions.push(region); // Keep track of regions for chart
        }

        // Add item data for the region
        ColumnChartData[region].data.push({
            y: orders,
            label: itemName
        });
    }

    // Prepare final dataPoints for CanvasJS
    var finalDataPoints = [];

    for (var r = 0; r < regions.length; r++) {
        var regionData = ColumnChartData[regions[r]].data;

        for (var j = 0; j < regionData.length; j++) {
            var itemName = regionData[j].label;
            var color = colorMapping[itemName] || "#000000"; // Use color from mapping or default to black

            finalDataPoints.push({
                y: regionData[j].y,
                label: itemName + " (" + regions[r] + ")", // Include region in label
                color: color // Assign the corresponding color
            });
        }
    }

    var Piechart = new CanvasJS.Chart("ChartContainerCitywise", {
        animationEnabled: true,
        animationDuration: 2000,
        title: {
            text: "Total Customer Region Wise",
            fontSize: 24,
            fontWeight: "bold"
        },
        axisX: {
            title: "Region",
            gridThickness: 1,
            gridColor: "#D3D3D3"
        },
        axisY: {
            title: "Count",
            includeZero: true,
            gridThickness: 1,
            gridColor: "#D3D3D3"
        },
        data: [{
            type: "column",
            dataPoints: finalDataPoints.map((point) => ({
                y: point.y,
                label: point.label,
                color: point.color, // Use the color assigned earlier
                toolTipContent: `<b>${point.label}</b>: ${point.y} visits`, // Tooltip content
                dataLabels: {
                    enabled: true,
                    format: `${point.y}` // Show the count
                }
            }))
        }],
        legend: {
            cursor: "pointer",
            verticalAlign: "bottom",
            horizontalAlign: "center"
        }
    });

    // Render the chart
    Piechart.render();



