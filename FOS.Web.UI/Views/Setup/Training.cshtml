@model FOS.Shared.AreaData
    @{
        ViewBag.Title = "Area";
        Layout = "~/Views/Shared/_Layout.cshtml";
    }

    <!-- BEGIN PAGE HEADER-->
    <div class="row-fluid">
        <div class="span12">
            <!-- BEGIN THEME CUSTOMIZER-->
            <!-- END THEME CUSTOMIZER-->
            <!-- BEGIN PAGE TITLE & BREADCRUMB-->
            <h3 class="page-title"></h3>
            <ul class="breadcrumb">
                <li>
                    <a href="#">Setup</a>
                    <span class="divider">/</span>
                </li>
                <li>
                    <a href="#">Manage Training</a>
                </li>
            </ul>
            <!-- END PAGE TITLE & BREADCRUMB-->
        </div>
    </div>
    @using (Ajax.BeginForm("AddTraining", "Setup", new AjaxOptions { OnSuccess = "OnSuccess", OnFailure = "OnFailure" }, new { @class = "form-horizontal" }))
    {
        @Html.AntiForgeryToken()

        @Html.ValidationSummary(true)

        <div class="row-fluid">
            <div class="span12">
                <!-- BEGIN SAMPLE FORMPORTLET-->
                <div class="widget green" style="">
                    <div class="widget-title">
                        <h4>Manage Training</h4>
                        <span class="tools">
                            @*<a href="javascript:;" class="icon-chevron-down"></a>*@
                            @*<a href="javascript:;" class="icon-remove"></a>*@
                        </span>
                    </div>
                    <div class="widget-body">

                        <!-- BEGIN FORM-->
                        <!-- Select Region -->
                        <div class="control-group">
                            <label class="control-label">Select Head *</label>
                            <div class="controls">
                                @Html.DropDownListFor(model => model.RegionID, new SelectList(Model.RegionalHead, "ID", "Name"), new { @class = "" })
                                @Html.ValidationMessageFor(model => model.RegionID)
                            </div>
                        </div>

                        <!-- Select City -->
                        <div class="control-group">
                            <label class="control-label">Select SO *</label>
                            <div class="controls">
                                @Html.DropDownListFor(model => model.CityID, new SelectList(Model.Salesofficerdata, "ID", "Name"), new { @class = "" })
                                @Html.ValidationMessageFor(model => model.CityID)
                            </div>
                        </div>

                        <!-- Area Name -->
                        <div class="control-group">
                            <label class="control-label">Training Value *</label>
                            <div class="controls">
                                @Html.EditorFor(model => model.Name)
                                @Html.ValidationMessageFor(model => model.Name)
                                @Html.HiddenFor(model => model.ID)
                            </div>
                        </div>

                        <!-- Short Code -->
                        

                        <!-- Buttons -->
                        <div class="control-group" style="border-top: 1px solid #e5e5e5;">
                            <div class="form-actions" style="padding-left:238px">
                                <button type="submit" id="btnNew" class="btn btn-primary">
                                    <i class="icon-ok icon-white" style="padding-right:8px"></i><span id="create">Create</span>
                                </button>
                                <button type="button" id="btnRefresh" class="btn btn-info"><i class="icon-ban-circle icon-white" style="padding-right:8px"></i>Reset</button>
                            </div>
                        </div>

                        <!-- END FORM-->
                    </div>
                </div>
                <!-- END SAMPLE FORM PORTLET-->
            </div>
        </div>
    }
    <!-- BEGIN EDITABLE TABLE widget-->
    <div class="row-fluid">
        <div class="span12">
            <!-- BEGIN EXAMPLE TABLE widget-->
            <div class="widget green">
                <div class="widget-title">
                    <h4>View Detail</h4>
                    <span class="tools">
                        @*<a href="javascript:;" class="icon-chevron-down"></a>*@
                        @*<a href="javascript:;" class="icon-remove"></a>*@
                    </span>
                </div>
                <div class="widget-body">
                    <div>
                        <div class="clearfix">
                            @*<div class="btn-group">
                                    <button id="editable-sample_new" class="btn green">
                                        Add New <i class="icon-plus"></i>
                                    </button>
                                </div>*@
                            <div class="btn-group pull-right"></div>
                        </div>
                        <div class="space15"></div>
                        <table class="table table-striped table-hover table-bordered" id="datatab" style="width: 100%;">
                            <thead>
                                <tr>
                                    <th>
                                        @Html.DisplayNameFor(model => model.ID)
                                    </th>
                                    <th>
                                        @Html.DisplayNameFor(model => model.RegionID)
                                    </th>
                                    <th>
                                        @Html.DisplayNameFor(model => model.CityID)
                                    </th>

                                    <th style="width: 10% !important">Sr #</th>

                                    <th style="width:40% !important">
                                        Value
                                    </th>

                                    <th style="width:40% !important">
                                        Head Name
                                    </th>

                                    <th style="width:40% !important">
                                        SO Name
                                    </th>
                                    <th style="width:10% !important">Actions</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
            <!-- END EXAMPLE TABLE widget-->
        </div>
    </div>
    <!-- END EDITABLE TABLE widget-->

    <script>
function GenerateDetailGrid() {
    // Destroy existing DataTable if it exists
    if ($.fn.DataTable.isDataTable('#datatab')) {
        $('#datatab').DataTable().destroy();
        $('#datatab tbody').empty();
    }

    var oTable = $('#datatab').DataTable({
        "aLengthMenu": [[10, 25, 50, 75, 100], [10, 25, 50, 75, 100]],
        "iDisplayLength": 10,
        "paging": true,
        "pagingType": "full_numbers",
        "serverSide": true,
        "bRetrieve": true,
        "bDestroy": true,
        "autoWidth": true,
        "ajax": {
            "type": "POST",
            "url": '@Url.Action("AddTrainingDataHandler", "Setup")',
            "contentType": 'application/json; charset=utf-8',
            "dataType": "json",
            "data": function (d) {
                // Add filter parameters
                d.CityID = $('#CityID').val();

                return JSON.stringify(d);
            },
            "error": function (xhr, error, thrown) {
                console.error("AJAX Error:", error);
                console.error("Status:", xhr.status);
                console.error("Response:", xhr.responseText);
                alertify.error("Error loading data. Please check console.");
            }
        },
        "columns": [
            { "data": "ID", "bVisible": false },
            { "data": "RegionID", "bVisible": false },
            { "data": "CityID", "bVisible": false },
            {
                "data": null,
                "bSortable": false,
                "render": function(data, type, row, meta) {
                    return meta.row + meta.settings._iDisplayStart + 1;
                }
            },
            {
                "data": "Name",
                "width": "40%",
                "bSortable": true
            },
            {
                "data": "RegionName",
                "width": "40%",
                "bSortable": true
            },
            {
                "data": "CityName",
                "width": "40%",
                "bSortable": true
            },
            {
                "data": null,
                "bSortable": false,
                "width": "10%",
                "className": "center-align-td",
                "render": function (data, type, row) {
                    // REMOVED EDIT BUTTON - Only showing delete button
                    return '<button class="btn btn-info delete" data-id="' + row.ID + '">' +
                           '<i class="icon-trash"></i>' +
                           '</button>';
                }
            }
        ],
        "fnDrawCallback": function (settings) {
            console.log("Table drawn");

            var DeleteCheck = "0";

            // Delete button handler
            if (DeleteCheck == "@HttpContext.Current.Session["DeleteCheck"]") {
                $(".delete").css("display", "none");
            } else {
                // Remove existing handlers to prevent duplicates
                $('#datatab').off('click', '.delete');
                $('#datatab').on('click', '.delete', function () {
                    var recordID = $(this).data('id');
                    var button = $(this);

                    alertify.confirm("Are You Sure You Want To Delete This Record?", function (e) {
                        if (e) {
                            $.ajax({
                                type: "POST",
                                url: "@Url.Action("DeleteAttendanceAndPunctuality", "Setup")",
                                data: { id: recordID },
                                success: function (data) {
                                    if (data == "0") {
                                        alertify.success('Record Deleted Successfully');
                                        // Refresh the table
                                        var table = $('#datatab').DataTable();
                                        table.ajax.reload(null, false); // false = keep current page
                                    } else {
                                        alertify.error(data || 'Error deleting record.');
                                    }
                                },
                                error: function() {
                                    alertify.error("Error communicating with server.");
                                }
                            });
                        }
                    });
                });
            }
        },
        "language": {
            "sSearch": "Search: ",
            "processing": '<i class="fa fa-spinner fa-spin fa-3x fa-fw"></i> Loading...',
            "emptyTable": "No data available",
            "zeroRecords": "No matching records found"
        },
        "sDom": 'lftipr',
        "order": [[4, "asc"]], // Changed to column 4 (Name column)
        "initComplete": function(settings, json) {
            console.log("DataTable initialized successfully");
        }
    });

    return oTable;
}
        function LoadCities() {
            try {
                var regionID = $("#RegionID").val();

                $.ajax({
                    type: "POST",
                    data: { RegionID: regionID },
                    url: "@Url.Action("GetTrainingListByID", "Setup")",
                    dataType: 'json',
                    success: function (json) {

                        var $el = $("#CityID");
                        $el.empty(); // remove old options
                        $.each(json, function (value, key) {

                            $el.append($("<option></option>")
                                    .val(key.ID).text(key.Name));
                        });

                        if ($('#CityID').val() != null) {
                            $('#datatab').dataTable().fnDestroy();
                            GenerateDetailGrid();
                        }
                        else {
                            $('#datatab').dataTable().empty();
                        }

                    }

                });
            } catch (e) {
                alert(e);
                $('#datatab').dataTable().fnDestroy();
            }

        }

        $(document).ready(function () {

            $("#liSetup,#liArea").addClass("active");

            var WriteCheck = "0";

            if (WriteCheck == "@HttpContext.Current.Session["WriteCheck"]") {
            // $("#btnNew").css("display", "none");
            $("#btnNew").attr("disabled", true);
        }
        else {
        }

        $("#RegionID").change(function () {

            LoadCities();
        });




        $("#CityID").change(function () {


                GenerateDetailGrid();



        });

        $("#btnRefresh").click(function () {
            ClearForm();
        });


        $("#ShortCode").bind('keyup', function (e) {
            if (e.which >= 97 && e.which <= 122) {
                var newKey = e.which - 32;
                // I have tried setting those
                e.keyCode = newKey;
                e.charCode = newKey;
            }

            $("#ShortCode").val(($("#ShortCode").val()).toUpperCase());
        });

    });

    </script>
    <script type="text/javascript">



        function ClearForm() {
            $('#Name').val('');
            $('#ShortCode').val('');
            $('#ID').val(0);
            $('#create').text('Create');
        }

        function OnSuccess(response) {
            if (response == "1") {
                alertify.success("Area Saved Successfully");
                $('#create').text('Create');
                var dt = $('#datatab').DataTable();
                dt.ajax.reload();
                ClearForm();
            }
            else if (response == "0") {
                alertify.error("Unable To Save Area.");
            }
            else if (response == "2") {
                alertify.error("Area Code Already Exist");
            }
            else {
                alertify.error(response);
            }

        }

        function OnFailure(response) {
            if (response.status == 422) {
                var errors = JSON.parse(response.responseText);
                alertify.error(errors.errors);
            }
            else {
                alertify.error(response);
            }
        }
    </script>